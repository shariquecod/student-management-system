# Copy to .env.local and restart the dev server after changes.

NODE_ENV=development

# External backend URL — used ONLY by Next.js server proxy routes (src/lib/backend-proxy.ts).
# Browser calls go to same-origin /api/v1/* and /api/auth/* — never directly to this URL.
NEXT_PUBLIC_API_BASE_URL=https://scholar-flow-backend-wp07.onrender.com

# Optional server-only alias (same value as above)
# API_BASE_URL=https://scholar-flow-backend-wp07.onrender.com

# AI Backend Production URL
NEXT_PUBLIC_API_AI_BASE_URL=
